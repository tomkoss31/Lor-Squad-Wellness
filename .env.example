# Supabase project URL (Dashboard → Settings → API → Project URL)
VITE_SUPABASE_URL=

# ⚠️ IMPORTANT (hotfix 2026-04-21) : utiliser UNIQUEMENT la clé anon legacy HS256.
# Dashboard → Settings → API → section "Legacy API keys" → anon public.
# Format attendu : eyJhbGciOiJIUzI1NiI... (JWT HS256).
# PAS la nouvelle clé publishable (sb_publishable_…  ou JWT ES256) : les Edge
# Functions la rejettent avec UNAUTHORIZED_UNSUPPORTED_TOKEN_ALGORITHM.
VITE_SUPABASE_ANON_KEY=

# Service role secret — Vercel only, jamais côté client (backend /api/*)
SUPABASE_SERVICE_ROLE_KEY=
